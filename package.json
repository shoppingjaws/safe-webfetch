{
	"name": "safe-webfetch",
	"version": "0.1.3",
	"description": "Claude Code permission prompt controller - auto allow/deny via pattern matching hooks",
	"type": "module",
	"bin": {
		"safe-webfetch": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/shoppingjaws/safe-webfetch"
	},
	"scripts": {
		"test": "bun test",
		"format": "biome format --write",
		"format:check": "biome format",
		"lint": "biome lint --fix",
		"lint:check": "biome lint",
		"typecheck": "tsc --noEmit",
		"build": "bun build --compile ./src/cli.ts --outfile ./dist/safe-webfetch",
		"build:npm": "bun build ./src/cli.ts --outdir ./dist --target bun",
		"prepublishOnly": "bun run build:npm"
	},
	"devDependencies": {
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"json5": "^2.2.3"
	},
	"engines": {
		"node": ">=22"
	}
}
