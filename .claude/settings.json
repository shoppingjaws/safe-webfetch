{
	"permissions": {
		"allow": [
			"Bash(bun run typecheck)",
			"Bash(bun run test)",
			"Bash(bun test:*)"
		],
		"ask": [
			"Edit(package.json)",
			"Edit(mise.toml)",
			"Edit(Dockerfile.test)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "cc-permission hook"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "cc-permission post-hook"
					}
				]
			}
		]
	}
}
